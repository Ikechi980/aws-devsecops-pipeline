# Shared development environment configuration

# AWS Configuration (LocalStack)
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://127.0.0.1:4666
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# SNS Topics
HEADEND_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:headend-messages
CORE_CHANGE_EVENTS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:core-change-events

# Services
STEP_CA_URL=https://localhost:9100
STEP_CA_CERTS_DIR=../infra/stepca/data/certs
STEP_CA_PROVISIONER_KEY_PATH=../infra/stepca/data/secrets/provisioner.key
MOCK_SYSTEMS_API_BASE_URL=http://localhost:8081
MOCK_CORE_RESOURCES_API_BASE_URL=http://localhost:8082
NGINX_PORT=8443
