# Server configuration
HOST=0.0.0.0
PORT=3000

# AWS configuration (LocalStack for local development)
AWS_ENDPOINT_URL=http://localhost:4666
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# SNS topic for message broadcasting
HEADEND_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:headend-messages

# Logging (optional)
RUST_LOG=info
