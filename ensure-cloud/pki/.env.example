# Application settings
RUST_LOG=info
HOST=0.0.0.0
PORT=8080

# Authorization
ALLOWED_CIDRS=127.0.0.1/32
SYSTEM_API_BASE=http://localhost:8081/communities/

# Step CA connection (for local dev, step-ca runs on localhost:9100)
STEP_CA_URL=https://localhost:9100
STEP_CA_CERTS_DIR=../infra/stepca/data/certs
STEP_CA_PROVISIONER_NAME=pki-api
STEP_CA_PROVISIONER_KEY_ID=
STEP_CA_PROVISIONER_KEY_PATH=../infra/stepca/data/secrets/provisioner.key
STEP_CA_TOKEN_TTL_SECS=300
