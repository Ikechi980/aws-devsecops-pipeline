# AWS configuration (LocalStack for local development)
AWS_ENDPOINT_URL=http://localhost:4666
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Optional bridge-specific source endpoint and queue (for cross-repo integration)
# BRIDGE_AWS_ENDPOINT_URL=http://localhost:4566
# BRIDGE_QUEUE_NAME=resources-events-test

# Ensure systems API
SYSTEMS_API_BASE_URL=http://localhost:8081

# SNS topic for headend-gateway delivery
HEADEND_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:headend-messages

# Logging (optional)
RUST_LOG=info
