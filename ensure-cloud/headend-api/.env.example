# Ensure systems API (ensure360-ems)
SYSTEMS_API_BASE_URL=http://localhost:8081

# Core resources API (sentrics-core)
CORE_RESOURCES_API_BASE_URL=http://localhost:8082

# Events MongoDB
EVENTS_MONGO_URL_SSM_PARAMETER=/ensure-cloud/headend-api/events-mongo-url

# Events query limits
EVENTS_LIMIT_DEFAULT=100
EVENTS_LIMIT_MAX=1000

# Local development only
ALLOW_UNAUTHENTICATED=1

# Logging (optional)
RUST_LOG=info
