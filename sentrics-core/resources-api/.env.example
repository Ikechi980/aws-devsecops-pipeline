# Logging
RUST_LOG=debug

# Database Configuration
# These values are provided by the shared infrastructure (../infra/dev.env)
# Override them here if you need to point to a different database
DATABASE_URL=postgres://postgres:password@localhost:5432/resources_db

# AWS Configuration
# These values are provided by the shared infrastructure (../infra/dev.env)
# Override them here if you need to point to staging or production services
AWS_ENDPOINT_URL=http://127.0.0.1:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# SNS Topic for publishing resource change events
# Provided by shared infrastructure - only override if pointing to remote AWS
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:resources-events

# Authentication
# Set to 1 for local development to bypass authentication
ALLOW_UNAUTHENTICATED=1
