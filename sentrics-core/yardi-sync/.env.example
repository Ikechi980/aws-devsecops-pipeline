# Logging
RUST_LOG=info

# AWS Configuration
# These values are provided by the shared infrastructure (../infra/dev.env)
# Override them here if you need to point to staging or production services
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://127.0.0.1:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Polling intervals
YARDI_POLL_INTERVAL_MS=500
RESOURCES_REFRESH_INTERVAL_SECS=30
# For production or staging, increase these intervals to reduce load and API calls:
# YARDI_POLL_INTERVAL_MS=10000
# RESOURCES_REFRESH_INTERVAL_SECS=300


# Service URLs
# Provided by shared infrastructure - only override if pointing to remote services
RESOURCES_API_BASE_URL=http://127.0.0.1:9000/lambda-url/resources-api/v1

# SQS/SNS Configuration
# Provided by shared infrastructure - only override if pointing to remote AWS
RESOURCES_EVENTS_QUEUE_URL=http://127.0.0.1:4566/000000000000/yardi-sync-events
FAILURE_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:yardi-sync-failures
