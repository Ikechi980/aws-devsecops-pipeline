# Shared development environment configuration
# These values are used by all services in local development

# AWS Configuration (LocalStack)
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://127.0.0.1:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# PostgreSQL (resources-api)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=resources_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/resources_db

# SNS Topics
RESOURCES_EVENTS_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:resources-events
YARDI_SYNC_FAILURES_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:yardi-sync-failures

# SQS Queues
RESOURCES_EVENTS_TEST_QUEUE_URL=http://127.0.0.1:4566/000000000000/resources-events-test
YARDI_SYNC_EVENTS_QUEUE_URL=http://127.0.0.1:4566/000000000000/yardi-sync-events
RESOURCES_CHANGE_LOGGER_QUEUE_URL=http://127.0.0.1:4566/000000000000/resources-change-logger-events

# DynamoDB Tables
CHANGE_LOG_TABLE_NAME=resources-change-log

# Service URLs
RESOURCES_API_BASE_URL=http://127.0.0.1:9000/lambda-url/resources-api/v1

# Mock Yardi API (for testing)
MOCK_YARDI_API_BASE_URL=http://localhost:3001
MOCK_YARDI_TOKEN_URL=http://localhost:3001/oauth/token

# Yardi API (yardi-sync should use mock in dev)
YARDI_API_BASE_URL=http://localhost:3001
YARDI_TOKEN_URL=http://localhost:3001/oauth/token
